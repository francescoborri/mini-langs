def main with input x output y as
    if x < 0 then
        y := -1
    else
        if x < 0 then
            y := 0
        else (
            y := 0;
            i := 1;
            while i < x do (
                if i * i < x then (
                    if x - (x * i) * i < 0 then (
                        y := y + 1;
                        if i * i < x then (
                            j := x * i;
                            if j < i then (
                                y := y + 1
                            ) else skip
                        ) else skip
                    ) else skip
                ) else skip;
                i := i + 1
            );
            a := 0;
            b := 1;
            while a < x do (
                if b < x then (
                    if a + b < x then (
                        a := a + b;
                        b := b + 1
                    ) else (
                        b := b + 1
                    )
                ) else (
                    a := x
                )
            );
            if y < 2 then (
                c := 0;
                d := 1;
                while d < y do (
                    if y - (y * d) * d < 0 then
                        c := c + 1
                    else
                        skip;
                    d := d + 1
                );
                if c < 1 then
                    y := y + c
                else
                    y := y
            ) else
                skip
        )
